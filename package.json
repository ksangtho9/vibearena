{
  "name": "vibearena",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Prompt-to-fighter stickman ragdoll arena. Type a fighter, step into the ring.",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,yellow \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build --config client/vite.config.ts",
    "preview": "vite preview --config client/vite.config.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "matter-js": "^0.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/matter-js": "^0.19.8",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
