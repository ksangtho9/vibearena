# Which LLM provider the server proxy uses: "groq" or "openrouter"
PROVIDER=groq

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
# Optional: override the Groq model (default: llama-3.1-8b-instant)
GROQ_MODEL=

# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: override the OpenRouter model (default: meta-llama/llama-3.1-8b-instruct:free)
OPENROUTER_MODEL=

# Server port (the Vite dev server proxies /api here)
PORT=8787
