# Which LLM provider the server proxy uses: "groq" or "openrouter"
PROVIDER=groq

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
# Model ROTATION pool, comma-separated, strongest first. Groq rate limits
# are per-model, so on a 429 the server tries the next model instead of
# falling to the mock — the order below runs best-first with the small
# model as last resort. (Default shown; edit to taste.)
GROQ_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-120b,openai/gpt-oss-20b,meta-llama/llama-4-scout-17b-16e-instruct
# Optional: pin a SINGLE model instead (overrides GROQ_MODELS entirely).
GROQ_MODEL=

# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: override the OpenRouter model (default: meta-llama/llama-3.1-8b-instruct:free)
OPENROUTER_MODEL=

# Server port (the Vite dev server proxies /api here)
PORT=8787

# Raw-JS ability scripts (LLM-authored, sandboxed + watchdogged). Fine for
# local self-generated fighters; set to false before any public deploy where
# fighter specs could be shared (see README "Security note").
VITE_ALLOW_CUSTOM_SCRIPT=true
